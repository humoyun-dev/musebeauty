# ───────────────────────── Namuna .env ─────────────────────────
# Nusxa oling:  cp .env.example .env  — va qiymatlarni to'ldiring.
# .env GIT'GA QO'YILMAYDI (maxfiy). .gitignore ga qarang.

# ─── Muhit ───
ENVIRONMENT=production          # production | development
DEBUG=false

# ─── PostgreSQL ───
DB_NAME=musebeauty
DB_USER=musebeauty
DB_PASSWORD=CHANGE_ME_strong_password
DB_HOST=postgres                # docker-compose servis nomi
DB_PORT=5432
# To'liq URL ham berish mumkin (yuqoridagilarni bekor qiladi). Bo'sh qoldirsangiz
# yuqoridagi DB_* dan yig'iladi. Mahalliy dev uchun SQLite:
#   DATABASE_URL=sqlite+aiosqlite:///./dev.db
DATABASE_URL=

# ─── Redis (FSM / savat / kesh) ───
REDIS_URL=redis://redis:6379/0

# ─── Telegram bot ───
BOT_TOKEN=123456:CHANGE_ME_botfather_token
# Admin Telegram ID'lari (vergul bilan): buyurtma xabarlari shularga keladi
ADMIN_TELEGRAM_IDS=111111111,222222222

# ─── Xavfsizlik (admin panel JWT) ───
# Tasodifiy uzun satr:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_random_long_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720          # 12 soat

# ─── To'lov (qo'lda) ───
# Mijozga ko'rsatiladigan karta — chek shu kartaga to'lanadi
PAYMENT_CARD_NUMBER=8600 0000 0000 0000
PAYMENT_CARD_HOLDER=MUSE BEAUTY

# ─── Domen (CORS uchun) ───
# Backend shu domenlarni CORS allow-origin'ga qo'shadi. SSL/proxy serverdagi
# nginx (Docker tashqarisida) tomonidan boshqariladi.
PUBLIC_DOMAIN=musebeauty.uz
ADMIN_DOMAIN=admin.musebeauty.uz

# ─── Rasm saqlash ───
STORAGE_BACKEND=disk            # disk | s3 (R2 uchun s3)
MEDIA_ROOT=/app/media           # disk: konteyner ichidagi papka (volume)
MEDIA_URL_BASE=/media           # disk rejimida serverdagi nginx shu yo'ldan beradi
# Cloudflare R2 (STORAGE_BACKEND=s3 bo'lsa). R2 → S3-mos:
S3_ENDPOINT=                    # https://<account_id>.r2.cloudflarestorage.com
S3_BUCKET=                      # bucket nomi, masalan musebeauty
S3_ACCESS_KEY=                  # R2 API token: Access Key ID
S3_SECRET_KEY=                  # R2 API token: Secret Access Key
S3_REGION=auto                  # R2 doim auto
S3_PUBLIC_URL=                  # https://pub-<hash>.r2.dev yoki https://cdn.musebeauty.uz

# ─── Payme (avtomatik to'lov) — kabinetdan olinadi ───
PAYME_ENABLED=false
PAYME_MERCHANT_ID=
PAYME_KEY=                      # kassa kaliti (webhook Basic auth paroli)

# ─── Click (avtomatik to'lov) — kabinetdan olinadi ───
CLICK_ENABLED=false
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
